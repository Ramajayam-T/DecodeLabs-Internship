import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# 1. Load the dataset
# Replace 'your_file_name.csv' with your actual file name
file_path = 'sample_data/california_housing_test.csv'

try:
    df = pd.read_csv(file_path)

    # 2. View basic info
    print("Dataset Preview:")
    display(df.head())

    # 3. Check for Missing Values
    print("\nMissing Values Count:")
    print(df.isnull().sum())

    # 4. Data Cleaning (Filling missing values with 0)
    df_cleaned = df.fillna(0)

    # 5. Visualization - Outliers Detection
    plt.figure(figsize=(12,6))
    sns.boxplot(data=df_cleaned.select_dtypes(include=['number']))
    plt.title('Outlier Analysis - Cleaned Data')
    plt.xticks(rotation=45)
    plt.show()

    # 6. Basic Statistics
    print("\nStatistical Summary:")
    display(df_cleaned.describe())

except Exception as e:
    print(f"Error occurred: {e}")
